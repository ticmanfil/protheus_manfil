/*/
User Function WSPG01(cDesc)
Local cQuery
local _cTabela:=""
Default cDesc:=""

cQuery:=" SELECT E4_CODIGO, E4_DESCRI FROM "+RetSqlName("SE4")+" WHERE D_E_L_E_T_ = ''
IF Alltrim(cDesc) <> ""
	cQuery+=" AND E4_DESCRI LIKE ('%"+Upper(NoAcento(cDesc))+"%') "
EndIF
cQuery+="AND E4_XFLUIG = 'S'"
cQuery+=" AND E4_MSBLQL <> '1' "
cQuery+=" ORDER BY E4_CODIGO"

dbUseArea( .T., "TOPCONN", TcGenQry(,,cQuery), "TRF", .T., .F. )

While !TRF->(EOF())
	AADD(aPG,{ TRF->E4_CODIGO, TRF->E4_DESCRI })
	TRF->(dbSkip())
EndDo
TRF->(dbCloseArea())

Return

