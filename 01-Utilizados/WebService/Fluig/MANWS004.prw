/*/
Static Function LoadORet(_aDados)

Local oRetorno 		:= WsClassNew("ESTRUTSE4") // Objeto de retorno generico
	
	IF Len(_aDados) > 0
		oRetorno:E4_CODIGO 		:= _aDados[1]
		oRetorno:E4_DESCRI		:= _aDados[2]
	Else
		oRetorno:E4_CODIGO		:= "ERRO DE SENHA"
		oRetorno:E4_DESCRI		:= "ERRO DE SENHA"
	EndIf

Return oRetorno
