/*/
//************************************************************************************************************
WsMethod BUSPG WsReceive cWSPWD, cDesc WsSend oCondPG WsService FATWPG
//************************************************************************************************************
Local cChave 	:= ::cWSPWD  //CHAVE DE VALIDAO ORIGEM
Local aExec 	:= {} //Retorno da fun鈬o que executa o MsExecAuto()
Local cPARPWD	:= '123456'//AllTrim(GetMv("MV_PWINTOP"))
Private aPG	:={}

conOut("[INFO] MANWS003 " + dtoc(date()) + " " + Time() +" ==> Montando Vetor de Procesamento com condicao pagto")

// VALIDA SE CHAVE ESTﾁ CORRETA
if AllTrim(cChave) == AllTrim(cPARPWD)
			ConOut("Antes da chamada da fun鈬o U_WSPG01")
			U_WSPG01(::cDesc)
			For nX:=1 to Len(aPG)
				AADD (oCondPG,LoadORet(aPG[nX]))
			Next
Else
	conOut("[ERRO] MANWS001.PRW " + dtoc(date()) + " " + Time() +"==>Chave de seguran軋 inv疝ida!")
	AADD (oCondPG,LoadORet(aPG))
EndIf

Return(.T.)
